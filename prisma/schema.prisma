generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum MatchStatus {
  OPEN
  IN_PROGRESS
  ARCADE_PENDING
  FINISHED
  CANCELLED
}

enum TransactionNetwork {
  INITIA
  FLOW
  SOLANA
}

enum TransactionType {
  ENTRY_STAKE
  ESCROW_LOCK
  PRIZE_PAYOUT
  BRIDGE_SYNC
}

enum TransactionStatus {
  PENDING
  SETTLED
  FAILED
}

enum ArcadeGameType {
  TARGET_RUSH
  MEMORY_GRID
  KEY_CLASH
  MAZE_RUNNER
  PING_PONG
  REACTION_DUEL
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  rating       Int           @default(0)
  bannedAt     DateTime?
  banReason    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  hostedMatches Match[]      @relation("HostMatches")
  joinedMatches Match[]      @relation("GuestMatches")
  wonMatches    Match[]      @relation("WinningMatches")
  wallets       Wallet[]
  transactions  Transaction[]
  bets          MatchBet[]
  attackDuels         ArcadeDuel[] @relation("AttackerDuels")
  defendDuels         ArcadeDuel[] @relation("DefenderDuels")
  wonDuels            ArcadeDuel[] @relation("WinnerDuels")
  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")
}

model Wallet {
  id        String             @id @default(cuid())
  network   TransactionNetwork
  address   String
  balance   String             @default("0")
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@unique([network, address])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Decimal  @db.Decimal(18, 6)
  token       String   @default("INIT")
  features    Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformConfig {
  id               String   @id @default(cuid())
  key              String   @unique @default("default")
  matchFeeBps      Int      @default(500)
  betFeeBps        Int      @default(300)
  arcadeFeeFixed   Decimal  @db.Decimal(18, 6) @default(0.050000)
  minEntryFee      Decimal  @db.Decimal(18, 6) @default(0.050000)
  enabledNetworks  Json     @default("[\"INITIA\"]")
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Match {
  id               String             @id @default(cuid())
  title            String
  theme            String
  boardTheme       String             @default("arena")
  stakeAmount      Decimal            @db.Decimal(18, 6)
  stakeToken       String             @default("INIT")
  entryFee         Decimal            @db.Decimal(18, 6) @default(0)
  preferredNetwork TransactionNetwork @default(INITIA)
  fen              String
  turn             String             @default("w")
  moveHistory      Json
  arcadeGamePool   Json
  isSolo           Boolean            @default(false)
  onchainMatchIndex Int?
  gameClockMs      Int                @default(300000)
  whiteClockMs     Int                @default(300000)
  blackClockMs     Int                @default(300000)
  turnStartedAt    DateTime?
  status           MatchStatus        @default(OPEN)
  hostId           String
  guestId          String?
  winnerId         String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  host             User               @relation("HostMatches", fields: [hostId], references: [id], onDelete: Cascade)
  guest            User?              @relation("GuestMatches", fields: [guestId], references: [id], onDelete: SetNull)
  winner           User?              @relation("WinningMatches", fields: [winnerId], references: [id], onDelete: SetNull)
  bets             MatchBet[]
  duels            ArcadeDuel[]
  transactions     Transaction[]

  @@index([status])
}

model MatchBet {
  id                String             @id @default(cuid())
  matchId           String
  userId            String
  network           TransactionNetwork
  predictedWinnerId String
  amount            Decimal            @db.Decimal(18, 6)
  payoutAmount      Decimal?           @db.Decimal(18, 6)
  token             String             @default("INIT")
  status            String             @default("OPEN")
  txHash            String?
  payoutTxHash      String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  settledAt         DateTime?
  match             Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId, status])
}

model ArcadeDuel {
  id                    String         @id @default(cuid())
  matchId               String
  attackerId            String
  defenderId            String
  gameType              ArcadeGameType
  seed                  String
  boardMove             Json
  attackerScore         Int?
  defenderScore         Int?
  winnerId              String?
  attackerEnteredAt     DateTime?
  defenderEnteredAt     DateTime?
  participationPenalty  String?
  resolvedAt            DateTime?
  createdAt             DateTime       @default(now())
  match                 Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  attacker              User           @relation("AttackerDuels", fields: [attackerId], references: [id], onDelete: Cascade)
  defender              User           @relation("DefenderDuels", fields: [defenderId], references: [id], onDelete: Cascade)
  winner                User?          @relation("WinnerDuels", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([matchId, resolvedAt])
}

model ArcadeGame {
  id                   String   @id @default(cuid())
  name                 String
  description          String
  gameType             ArcadeGameType
  baseScore            Int      @default(1000)
  difficultyMultiplier Decimal  @db.Decimal(4, 2) @default(1.0)
  isEnabled            Boolean  @default(true)
  contractAddresses    Json     // { INITIA: "0x...", FLOW: "0x...", SOLANA: "..." }
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([gameType])
}

model TutorialVideo {
  id          String   @id @default(cuid())
  title       String
  description String?
  youtubeUrl  String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Friendship {
  id        String           @id @default(cuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  user      User             @relation("SentFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User             @relation("ReceivedFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model Transaction {
  id        String             @id @default(cuid())
  userId    String
  matchId   String?
  network   TransactionNetwork
  type      TransactionType
  status    TransactionStatus  @default(PENDING)
  amount    Decimal            @db.Decimal(18, 6)
  token     String             @default("INIT")
  txHash    String?
  metadata  Json?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match?             @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([network, status])
}
